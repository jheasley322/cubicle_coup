# Front-end build config. Copy to .env.local for local dev (gitignored).
# Both values are safe to expose in the browser — the anon key is gated by RLS
# and Edge Functions; the real secret (service_role) never leaves Supabase.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
